---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A personal writing site." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site-wrapper">
      <header>
        <a href="/" class="site-name">Frances Wang</a>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <p>Written with care &middot; <a href="mailto:siqin.frances.wang@gmail.com">siqin.frances.wang@gmail.com</a></p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg:         #faf8f5;
    --bg-subtle:  #f3efe9;
    --border:     #e4ddd4;
    --text:       #2d2926;
    --text-muted: #9c8b7e;
    --accent:     #7a5c3a;
    --accent-hover: #5e4428;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: 'Lora', Georgia, serif;
    font-size: 18px;
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
  }

  .site-wrapper {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  header {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .site-name {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .site-name:hover {
    color: var(--accent);
  }

  /* Footer */
  footer {
    margin-top: 5rem;
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: 'Inter', sans-serif;
  }

  footer a {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  footer a:hover {
    color: var(--accent);
  }

  /* Links */
  a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s ease, color 0.15s ease;
  }

  a:hover {
    color: var(--accent-hover);
    text-decoration-color: currentColor;
  }

  /* Prose styles for essay content */
  .prose h1, .prose h2, .prose h3 {
    font-family: 'Lora', Georgia, serif;
    font-weight: 600;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .prose h1 { font-size: 1.8rem; }
  .prose h2 { font-size: 1.35rem; }
  .prose h3 { font-size: 1.1rem; }

  .prose p {
    margin-bottom: 1.5rem;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  .prose a {
    text-decoration-color: currentColor;
  }

  .prose blockquote {
    border-left: 3px solid var(--border);
    padding-left: 1.25rem;
    margin: 2rem 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.4rem;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
  }

  .prose em {
    font-style: italic;
  }

  .prose strong {
    font-weight: 600;
  }

  .prose code {
    font-size: 0.875em;
    background: var(--bg-subtle);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-family: 'Courier New', monospace;
  }

  /* Images */
  .prose img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 2rem 0 0.5rem;
    display: block;
  }

  .prose img + em {
    display: block;
    text-align: center;
    font-size: 0.82rem;
    color: var(--text-muted);
    font-style: normal;
    font-family: 'Inter', sans-serif;
    margin-bottom: 2rem;
    margin-top: 0;
  }

  /* Two-up photo grid: wrap two images in a blockquote to display side by side */
  .prose .photo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 2rem 0;
  }

  .prose .photo-grid img {
    margin: 0;
    height: 260px;
    object-fit: cover;
  }
</style>
