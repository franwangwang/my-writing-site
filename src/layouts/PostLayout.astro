---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  readTime?: string;
}

const { title, date, description, readTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="post-header">
      <div class="meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {readTime && <span class="read-time">{readTime}</span>}
      </div>
      <h1>{title}</h1>
      {description && <p class="description">{description}</p>}
    </header>
    <div class="prose">
      <slot />
    </div>
    <nav class="post-nav">
      <a href="/">&larr; All essays</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .read-time::before {
    content: '·';
    margin-right: 1rem;
  }

  h1 {
    font-family: 'Lora', Georgia, serif;
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  .description {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-top: 0.5rem;
  }

  .post-nav {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .post-nav a:hover {
    color: var(--text);
  }
</style>
